{
  "name": "@repo/db",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./lib/db": {
      "types": "./src/lib/db.ts",
      "default": "./src/lib/db.ts"
    },
    "./models/*": {
      "types": "./src/models/*.ts",
      "default": "./src/models/*.ts"
    },
    "./lib/*": {
      "types": "./src/lib/*.ts",
      "default": "./src/lib/*.ts"
    }
  },
  "scripts": {
    "db:pull": "drizzle-kit introspect",
    "db:generate": "drizzle-kit generate",
    "db:introspect": "drizzle-kit introspect",
    "db:migrate": "drizzle-kit migrate",
    "db:drop": "drizzle-kit drop",
    "db:up": "drizzle-kit up",
    "db:check": "drizzle-kit check",
    "db:push": "drizzle-kit push",
    "db:studio": "NODE_ENV=development drizzle-kit studio",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.29.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.37.0",
    "drizzle-zod": "^0.5.1",
    "postgres": "^3.4.5"
  }
}
